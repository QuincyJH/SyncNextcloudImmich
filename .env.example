# Copy to .env and fill with your values
# Used by docker-compose.yml for variable substitution

# Immich server base URL (e.g., https://immich.yourdomain.com)
IMMICH_SERVER=

# Nextcloud database connection
NEXTCLOUD_DB_HOST=
NEXTCLOUD_DB_PORT=5432
NEXTCLOUD_DB_NAME=
NEXTCLOUD_DB_USER=
NEXTCLOUD_DB_PASSWORD=

# Optional runtime settings
LOG_LEVEL=INFO
TZ=UTC
